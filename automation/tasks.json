{
  "tasks": [
    {
      "id": "update_timestamp",
      "type": "update_timestamp",
      "enabled": true,
      "out_file": "automation/last_run.txt"
    },
    {
      "id": "echo_message",
      "type": "shell",
      "enabled": true,
      "command": "echo 'Auto worker executed at ' $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
    },
    {
      "id": "test_report",
      "type": "generate_report",
      "enabled": true,
      "paths": ["会议记录", "学校方案", "提示词模版"],
      "out_file": "automation/test_report.md"
    }
  ]
}